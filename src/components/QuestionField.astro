---
const questions = [
	["JavaScript", "Why does JavaScript exist?"],
	["Objects", "Why do objects exist?"],
	["React", "Why was React created?"],
	["TypeScript", "Why does TypeScript exist?"],
	["WebAssembly", "Why does WebAssembly exist?"],
	["Distributed Systems", "Why do distributed systems fail?"],
];
---

<section class="question-field scene" aria-labelledby="question-field-title">
	<header class="topline" data-reveal>
		<a class="brand" href="/" aria-label="Learning Lab home">Learning Lab</a>
		<nav class="nav" aria-label="Primary">
			<a href="#method">Method</a>
			<a href="#paths">Paths</a>
		</nav>
	</header>

	<div class="field-shell">
		<div class="question-system" aria-hidden="true">
			{
				questions.map(([name, question], index) => (
					<div class={`question-node question-node-${index + 1}`}>
						<span class="question-name">{name}</span>
						<span class="question-text">{question}</span>
					</div>
				))
			}
		</div>

		<div class="hero-copy" data-reveal>
			<p class="eyebrow">First-principles technology learning</p>
			<h1 id="question-field-title">Why does this exist?</h1>
			<p class="hero-line">
				The tools are familiar. The reasons behind them are usually hidden.
			</p>
		</div>
	</div>

	<div class="scroll-cue" aria-hidden="true" data-reveal>
		<span></span>
		Explore the question
	</div>
</section>

<style>
	.scene {
		position: relative;
		min-height: 100svh;
		padding: 30px clamp(20px, 4vw, 64px);
	}

	.question-field {
		display: grid;
		grid-template-rows: auto 1fr auto;
		isolation: isolate;
	}

	.topline {
		position: relative;
		z-index: 5;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		width: min(100%, var(--lab-max));
		margin: 0 auto;
		font-size: 12px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.brand,
	.nav a {
		text-decoration: none;
	}

	.brand {
		color: var(--lab-text);
		font-weight: 700;
	}

	.nav {
		display: flex;
		gap: clamp(16px, 3vw, 34px);
		color: var(--lab-faint);
	}

	.nav a {
		transition: color 220ms ease;
	}

	.nav a:hover {
		color: var(--lab-text);
	}

	.field-shell {
		position: relative;
		display: grid;
		place-items: center;
		width: min(100%, var(--lab-max));
		margin: 0 auto;
	}

	.hero-copy {
		position: relative;
		z-index: 2;
		max-width: 920px;
		text-align: center;
	}

	.eyebrow {
		margin: 0 0 22px;
		color: var(--lab-amber);
		font-family: var(--font-mono);
		font-size: clamp(11px, 1vw, 13px);
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		max-width: 10ch;
		color: var(--lab-text);
		font-size: clamp(64px, 13vw, 178px);
		font-weight: 780;
		letter-spacing: 0;
		line-height: 0.86;
		text-wrap: balance;
	}

	.hero-line {
		max-width: 620px;
		margin: 30px auto 0;
		color: var(--lab-muted);
		font-size: clamp(18px, 2.2vw, 28px);
		line-height: 1.28;
		text-wrap: balance;
	}

	.question-system {
		position: absolute;
		inset: 3% 0;
		z-index: 1;
	}

	.question-system::before {
		position: absolute;
		inset: 6% 10%;
		content: "";
		border: 1px solid var(--lab-line);
		border-radius: 999px;
		transform: rotate(-8deg);
	}

	.question-system::after {
		position: absolute;
		inset: 24% 23%;
		content: "";
		border: 1px solid rgba(240, 184, 90, 0.13);
		border-radius: 999px;
		transform: rotate(13deg);
	}

	.question-node {
		position: absolute;
		display: grid;
		gap: 8px;
		width: min(270px, 34vw);
		padding-left: 17px;
		color: var(--lab-faint);
		font-family: var(--font-mono);
		font-size: clamp(10px, 1vw, 12px);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		animation: nodeDrift 9s ease-in-out infinite alternate;
	}

	.question-node::before {
		position: absolute;
		top: 4px;
		left: 0;
		width: 7px;
		height: 7px;
		content: "";
		background: var(--lab-cyan);
		border-radius: 999px;
		box-shadow: 0 0 22px rgba(146, 232, 255, 0.8);
	}

	.question-name {
		opacity: 0.8;
		transition: opacity 420ms ease;
	}

	.question-text {
		position: absolute;
		top: 0;
		left: 17px;
		max-width: 30ch;
		color: var(--lab-text);
		opacity: 0;
		transition: opacity 420ms ease;
	}

	.question-node:hover .question-name {
		opacity: 0;
	}

	.question-node:hover .question-text {
		opacity: 1;
	}

	.question-node-1 {
		top: 17%;
		left: 8%;
	}

	.question-node-2 {
		top: 10%;
		right: 19%;
		animation-delay: -2s;
	}

	.question-node-3 {
		top: 48%;
		right: 5%;
		animation-delay: -4s;
	}

	.question-node-4 {
		bottom: 14%;
		right: 26%;
		animation-delay: -1s;
	}

	.question-node-5 {
		bottom: 20%;
		left: 9%;
		animation-delay: -5s;
	}

	.question-node-6 {
		top: 44%;
		left: 0;
		animation-delay: -3s;
	}

	.scroll-cue {
		display: flex;
		align-items: center;
		gap: 12px;
		width: min(100%, var(--lab-max));
		margin: 0 auto;
		color: var(--lab-faint);
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.scroll-cue span {
		display: block;
		width: 42px;
		height: 1px;
		background: var(--lab-line-strong);
		transform-origin: left;
		animation: cueLine 1.8s ease-in-out infinite;
	}

	@keyframes nodeDrift {
		from {
			transform: translate3d(0, 0, 0);
		}

		to {
			transform: translate3d(0, -13px, 0);
		}
	}

	@keyframes cueLine {
		0%,
		100% {
			transform: scaleX(0.45);
			opacity: 0.45;
		}

		50% {
			transform: scaleX(1);
			opacity: 1;
		}
	}

	@media (max-width: 820px) {
		.scene {
			padding: 22px 18px;
		}

		.topline {
			align-items: flex-start;
			font-size: 10px;
		}

		.nav {
			gap: 14px;
		}

		.question-system {
			inset: 5% -16%;
		}

		.question-node {
			width: 190px;
			opacity: 0.74;
		}

		.question-node-3,
		.question-node-6 {
			display: none;
		}

		.hero-copy {
			text-align: left;
		}

		h1 {
			max-width: 8ch;
		}

		.hero-line {
			margin-left: 0;
		}
	}
</style>
