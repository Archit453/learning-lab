---
const paths = [
	["React", "Why did interfaces become state problems?", "Future path"],
	["TypeScript", "Why did JavaScript need contracts?", "Future path"],
	["Backend", "Why did logic move behind interfaces?", "Future path"],
	["Tailwind CSS", "Why did styling become compositional?", "Future path"],
	["System Design", "Why do systems fail at scale?", "Future path"],
	["DevOps", "Why did deployment become a discipline?", "Future path"],
	["Security", "Why is trust never automatic?", "Future path"],
	["AI", "Why did prediction become programmable?", "Future path"],
];
---

<section class="paths-scene scene" id="paths" aria-labelledby="paths-title">
	<div class="scene-inner">
		<div class="paths-map" data-reveal aria-label="Future Learning Lab paths">
			<div class="active-path">
				<p class="status">Active path</p>
				<h2 id="paths-title">JavaScript</h2>
				<p class="active-question">Why does JavaScript exist?</p>
				<a href="/" class="path-cta" aria-label="Enter JavaScript Path">Enter JavaScript Path</a>
			</div>

			{
				paths.map(([name, question, status], index) => (
					<article class={`path-node path-node-${index + 1}`}>
						<p>{status}</p>
						<h3>{name}</h3>
						<span>{question}</span>
					</article>
				))
			}
		</div>

		<div class="closing" data-reveal>
			<p class="eyebrow">Learning begins before the answer</p>
			<h2>Start with the question.</h2>
			<p>
				Learning Lab teaches technology through the problems, constraints, tradeoffs,
				and mental models that shaped it.
			</p>
		</div>
	</div>
</section>

<style>
	.scene {
		position: relative;
		min-height: 100svh;
		padding: clamp(86px, 12vw, 150px) clamp(20px, 4vw, 64px) clamp(64px, 9vw, 110px);
	}

	.scene-inner {
		display: grid;
		gap: clamp(64px, 8vw, 108px);
		width: min(100%, var(--lab-max));
		margin: 0 auto;
	}

	.paths-map {
		position: relative;
		min-height: 720px;
		border: 1px solid rgba(245, 241, 232, 0.11);
		background:
			radial-gradient(circle at 50% 45%, rgba(146, 232, 255, 0.12), transparent 21rem),
			linear-gradient(135deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.012));
		overflow: hidden;
	}

	.paths-map::before {
		position: absolute;
		inset: 9%;
		content: "";
		border: 1px solid var(--lab-line);
		border-radius: 999px;
	}

	.paths-map::after {
		position: absolute;
		inset: 20% 15%;
		content: "";
		border: 1px solid rgba(240, 184, 90, 0.12);
		border-radius: 999px;
		transform: rotate(-12deg);
	}

	.active-path {
		position: absolute;
		z-index: 3;
		top: 50%;
		left: 50%;
		display: grid;
		place-items: center;
		width: min(420px, calc(100% - 42px));
		min-height: 320px;
		padding: 38px;
		text-align: center;
		border: 1px solid rgba(146, 232, 255, 0.38);
		background:
			radial-gradient(circle at 50% 0%, rgba(146, 232, 255, 0.18), transparent 72%),
			rgba(5, 8, 10, 0.82);
		box-shadow:
			0 0 80px rgba(146, 232, 255, 0.12),
			inset 0 0 0 1px rgba(255, 255, 255, 0.04);
		transform: translate(-50%, -50%);
	}

	.status,
	.path-node p,
	.eyebrow {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.status {
		color: var(--lab-green);
	}

	.active-path h2 {
		margin: 12px 0 0;
		color: var(--lab-text);
		font-size: clamp(46px, 6.8vw, 90px);
		font-weight: 780;
		letter-spacing: 0;
		line-height: 0.94;
	}

	.active-question {
		max-width: 25ch;
		margin: 18px auto 0;
		color: var(--lab-muted);
		font-size: clamp(18px, 2vw, 24px);
		line-height: 1.25;
		text-wrap: balance;
	}

	.path-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		margin-top: 28px;
		padding: 0 20px;
		color: var(--lab-black);
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-decoration: none;
		text-transform: uppercase;
		background: var(--lab-text);
		transition:
			background 220ms ease,
			transform 220ms ease;
	}

	.path-cta:hover {
		background: var(--lab-cyan);
		transform: translateY(-2px);
	}

	.path-node {
		position: absolute;
		z-index: 2;
		width: min(245px, 24vw);
		padding: 18px;
		border: 1px solid rgba(245, 241, 232, 0.12);
		background: rgba(5, 7, 9, 0.54);
		backdrop-filter: blur(10px);
		opacity: 0.72;
	}

	.path-node::before {
		position: absolute;
		top: 50%;
		left: 50%;
		z-index: -1;
		width: 74px;
		height: 1px;
		content: "";
		background: var(--lab-line);
		transform-origin: left;
	}

	.path-node p {
		color: var(--lab-faint);
	}

	.path-node h3 {
		margin: 12px 0 9px;
		color: rgba(245, 241, 232, 0.78);
		font-size: clamp(19px, 1.8vw, 25px);
		font-weight: 680;
		letter-spacing: 0;
		line-height: 1;
	}

	.path-node span {
		display: block;
		color: rgba(245, 241, 232, 0.5);
		font-size: 14px;
		line-height: 1.35;
	}

	.path-node-1 {
		top: 10%;
		left: 14%;
	}

	.path-node-1::before {
		transform: rotate(31deg);
	}

	.path-node-2 {
		top: 11%;
		right: 12%;
	}

	.path-node-2::before {
		transform: rotate(146deg);
	}

	.path-node-3 {
		top: 37%;
		left: 5%;
	}

	.path-node-3::before {
		transform: rotate(12deg);
	}

	.path-node-4 {
		top: 38%;
		right: 4%;
	}

	.path-node-4::before {
		transform: rotate(170deg);
	}

	.path-node-5 {
		bottom: 11%;
		left: 13%;
	}

	.path-node-5::before {
		transform: rotate(-22deg);
	}

	.path-node-6 {
		right: 16%;
		bottom: 10%;
	}

	.path-node-6::before {
		transform: rotate(205deg);
	}

	.path-node-7 {
		top: 64%;
		left: 36%;
		transform: translateX(-50%);
	}

	.path-node-7::before {
		transform: rotate(-66deg);
	}

	.path-node-8 {
		top: 64%;
		right: 34%;
		transform: translateX(50%);
	}

	.path-node-8::before {
		transform: rotate(246deg);
	}

	.closing {
		display: grid;
		justify-items: center;
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}

	.eyebrow {
		margin-bottom: 22px;
		color: var(--lab-amber);
	}

	.closing h2 {
		margin: 0;
		font-size: clamp(48px, 9vw, 126px);
		font-weight: 780;
		letter-spacing: 0;
		line-height: 0.9;
		text-wrap: balance;
	}

	.closing p:not(.eyebrow) {
		max-width: 680px;
		margin: 28px 0 0;
		color: var(--lab-muted);
		font-size: clamp(17px, 1.8vw, 23px);
		line-height: 1.42;
		text-wrap: balance;
	}

	@media (max-width: 980px) {
		.paths-map {
			display: grid;
			gap: 14px;
			min-height: auto;
			padding: 18px;
		}

		.paths-map::before,
		.paths-map::after {
			inset: 18px;
			border-radius: 0;
		}

		.active-path,
		.path-node {
			position: relative;
			inset: auto;
			width: 100%;
			transform: none;
		}

		.active-path {
			min-height: auto;
			padding: 34px 20px;
			order: -1;
		}

		.path-node::before {
			display: none;
		}
	}

	@media (max-width: 620px) {
		.scene {
			padding: 90px 18px 64px;
		}

		.path-cta {
			width: 100%;
		}
	}
</style>
