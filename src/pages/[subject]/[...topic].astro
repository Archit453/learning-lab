---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const subjects = await getCollection("subjects");
	const activeSubjectSlugs = new Set(
		subjects.filter((subject) => subject.data.status === "active").map((subject) => subject.data.slug),
	);
	const topics = await getCollection("topics");
	const topicOrders = await getCollection("topicOrders");
	const paths = [];

	for (const order of topicOrders) {
		if (!activeSubjectSlugs.has(order.data.subject)) {
			continue;
		}

		const subjectTopics = topics.filter((topic) => topic.data.subject === order.data.subject);
		const orderedTopics = order.data.topics
			.map((slug) => subjectTopics.find((topic) => topic.data.slug === slug))
			.filter(Boolean);
		const unorderedTopics = subjectTopics.filter(
			(topic) => !order.data.topics.includes(topic.data.slug),
		);
		const displayTopics = [...orderedTopics, ...unorderedTopics];

		for (const [index, topic] of displayTopics.entries()) {
			const subject = subjects.find((subject) => subject.data.slug === order.data.subject);

			paths.push({
				params: { subject: order.data.subject, topic: topic.data.slug },
				props: {
					subject,
					topic,
					subjectTopics: displayTopics,
					previousTopic: displayTopics[index - 1] ?? null,
					nextTopic: displayTopics[index + 1] ?? null,
				},
			});
		}
	}

	const orderedSubjectSlugs = new Set(topicOrders.map((order) => order.data.subject));
	const unorderedSubjects = subjects.filter(
		(subject) => subject.data.status === "active" && !orderedSubjectSlugs.has(subject.data.slug),
	);

	for (const subject of unorderedSubjects) {
		const subjectTopics = topics.filter((topic) => topic.data.subject === subject.data.slug);

		for (const [index, topic] of subjectTopics.entries()) {
			paths.push({
				params: { subject: subject.data.slug, topic: topic.data.slug },
				props: {
					subject,
					topic,
					subjectTopics,
					previousTopic: subjectTopics[index - 1] ?? null,
					nextTopic: subjectTopics[index + 1] ?? null,
				},
			});
		}
	}

	return paths;
}

const { subject, topic, subjectTopics, previousTopic, nextTopic } = Astro.props;
const currentTopicIndex = subjectTopics.findIndex(
	(subjectTopic) => subjectTopic.data.slug === topic.data.slug,
);

const defaultGroupDefinition = [
	{ title: "Foundations", slugs: ["why-javascript-exists", "data-types", "operators", "loops"] },
	{ title: "Language Mechanics", slugs: ["functions", "scope", "closures"] },
	{ title: "Runtime", slugs: ["event-loop"] },
];

const groupDefinitionsBySubject = {
	javascript: defaultGroupDefinition,
};

function getInvestigationGroups(subjectSlug, topics) {
	const definitions = groupDefinitionsBySubject[subjectSlug] ?? [
		{ title: "Investigations", slugs: topics.map((topic) => topic.data.slug) },
	];
	const topicMap = new Map(topics.map((topic) => [topic.data.slug, topic]));
	const usedSlugs = new Set();
	const groups = definitions
		.map((group) => {
			const groupTopics = group.slugs.map((slug) => topicMap.get(slug)).filter(Boolean);

			for (const groupTopic of groupTopics) {
				usedSlugs.add(groupTopic.data.slug);
			}

			return { title: group.title, topics: groupTopics };
		})
		.filter((group) => group.topics.length > 0);
	const uncategorizedTopics = topics.filter((topic) => !usedSlugs.has(topic.data.slug));

	if (uncategorizedTopics.length > 0) {
		groups.push({ title: "More Investigations", topics: uncategorizedTopics });
	}

	return groups;
}

const investigationGroups = getInvestigationGroups(subject.data.slug, subjectTopics);
---

<Layout>
	<main class="topic-page">
		<nav class="orientation" aria-label="Breadcrumb">
			<a class="home-link" href="/">
				<span aria-hidden="true">&lt;-</span>
				<span>Learning Lab</span>
			</a>
			<div class="breadcrumb">
				<a href={`/${topic.data.subject}`}>{subject.data.title}</a>
				<span aria-hidden="true">/</span>
				<span>{topic.data.title}</span>
			</div>
		</nav>

		<details class="investigation-map">
			<summary>
				<span>Map of Investigations</span>
				<span aria-hidden="true">▾</span>
			</summary>
			<div class="map-panel">
				{
					investigationGroups.map((group) => (
						<section class="map-group" aria-label={group.title}>
							<h2>{group.title}</h2>
							<ol>
								{
									group.topics.map((mapTopic) => {
										const mapTopicIndex = subjectTopics.findIndex(
											(subjectTopic) => subjectTopic.data.slug === mapTopic.data.slug,
										);
										const marker =
											mapTopic.data.slug === topic.data.slug
												? "●"
												: mapTopicIndex < currentTopicIndex
													? "✓"
													: "○";

										return (
											<li>
												<a
													class:list={[
														"map-link",
														{ "is-current": mapTopic.data.slug === topic.data.slug },
													]}
													href={`/${subject.data.slug}/${mapTopic.data.slug}`}
													aria-current={mapTopic.data.slug === topic.data.slug ? "page" : undefined}
												>
													<span class="map-marker" aria-hidden="true">{marker}</span>
													<span>{mapTopic.data.title}</span>
												</a>
											</li>
										);
									})
								}
							</ol>
						</section>
					))
				}
			</div>
		</details>

		<article class="topic-shell" aria-labelledby="topic-title">
			<p class="eyebrow">Investigation</p>
			<h1 id="topic-title">{topic.data.title}</h1>
			{topic.data.subtitle && <p class="subtitle">{topic.data.subtitle}</p>}

			<div class="placeholder">
				<p>UNDER CONSTRUCTION</p>
				<p>Content coming soon.</p>
			</div>
		</article>

		<nav class="topic-navigation" aria-label="Topic navigation">
			{
				previousTopic ? (
					<a href={`/${topic.data.subject}/${previousTopic.data.slug}`}>
						<span aria-hidden="true">&lt;-</span>
						<span>
							<span class="nav-label">Previous Topic</span>
							<span class="nav-title">{previousTopic.data.title}</span>
						</span>
					</a>
				) : (
					<a href={`/${topic.data.subject}`}>
							<span aria-hidden="true">&lt;-</span>
						<span>
							<span class="nav-label">Subject Index</span>
							<span class="nav-title">{subject.data.title}</span>
						</span>
					</a>
				)
			}

			{
				nextTopic && (
					<a class="next" href={`/${topic.data.subject}/${nextTopic.data.slug}`}>
						<span>
							<span class="nav-label">Next Topic</span>
							<span class="nav-title">{nextTopic.data.title}</span>
						</span>
						<span aria-hidden="true">-&gt;</span>
					</a>
				)
			}
		</nav>
	</main>
</Layout>

<style>
	.topic-page {
		display: grid;
		gap: clamp(28px, 5vw, 56px);
		width: min(100%, 920px);
		margin: 0 auto;
		padding: clamp(28px, 6vw, 76px) clamp(18px, 4vw, 42px) clamp(46px, 8vw, 96px);
	}

	.orientation,
	.breadcrumb,
	.eyebrow,
	.placeholder p:first-child,
	.nav-label {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.orientation {
		display: grid;
		gap: 12px;
		align-items: start;
		color: var(--lab-faint);
	}

	.home-link {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		width: fit-content;
		color: var(--lab-faint);
		font-weight: 700;
		text-decoration: none;
		transition:
			color 220ms ease,
			transform 220ms ease;
	}

	.home-link:hover {
		color: var(--lab-cyan);
		transform: translateX(-2px);
	}

	.breadcrumb {
		display: flex;
		gap: 10px;
		align-items: center;
		flex-wrap: wrap;
		color: var(--lab-faint);
	}

	.breadcrumb a {
		color: var(--lab-muted);
		text-decoration: none;
		transition: color 220ms ease;
	}

	.breadcrumb a:hover {
		color: var(--lab-cyan);
	}

	.investigation-map {
		width: 100%;
	}

	.investigation-map summary {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		width: fit-content;
		color: var(--lab-muted);
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		cursor: pointer;
		list-style: none;
		transition: color 220ms ease;
	}

	.investigation-map summary::-webkit-details-marker {
		display: none;
	}

	.investigation-map summary:hover {
		color: var(--lab-cyan);
	}

	.investigation-map[open] summary span:last-child {
		transform: rotate(180deg);
	}

	.investigation-map summary span:last-child {
		transition: transform 220ms ease;
	}

	.map-panel {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
		margin-top: 18px;
		padding: 20px 0 2px;
		border-top: 1px solid var(--lab-line);
	}

	.map-group {
		display: grid;
		gap: 12px;
		min-width: 0;
	}

	.map-group h2 {
		margin: 0;
		color: var(--lab-faint);
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.map-group ol {
		display: grid;
		gap: 8px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.map-link {
		display: inline-flex;
		gap: 10px;
		align-items: baseline;
		max-width: 100%;
		color: var(--lab-muted);
		font-size: 15px;
		line-height: 1.35;
		text-decoration: none;
		transition: color 220ms ease;
	}

	.map-link:hover,
	.map-link.is-current {
		color: var(--lab-text);
	}

	.map-marker {
		flex: 0 0 auto;
		color: var(--lab-faint);
		font-family: var(--font-mono);
		font-size: 12px;
	}

	.map-link.is-current .map-marker {
		color: var(--lab-cyan);
	}

	.topic-shell {
		display: grid;
		gap: 22px;
		padding: clamp(34px, 6vw, 68px);
		border: 1px solid rgba(245, 241, 232, 0.12);
		background:
			radial-gradient(circle at 85% 0%, rgba(240, 184, 90, 0.09), transparent 22rem),
			rgba(255, 255, 255, 0.028);
	}

	.eyebrow {
		margin: 0;
		color: var(--lab-amber);
	}

	h1 {
		margin: 0;
		color: var(--lab-text);
		font-size: clamp(46px, 8vw, 96px);
		font-weight: 780;
		letter-spacing: 0;
		line-height: 0.92;
		text-wrap: balance;
	}

	.subtitle {
		max-width: 700px;
		margin: 0;
		color: var(--lab-muted);
		font-size: clamp(18px, 2vw, 24px);
		line-height: 1.42;
		text-wrap: balance;
	}

	.placeholder {
		display: grid;
		gap: 12px;
		margin-top: clamp(28px, 5vw, 54px);
		padding-top: clamp(24px, 4vw, 38px);
		border-top: 1px solid var(--lab-line);
	}

	.placeholder p {
		margin: 0;
	}

	.placeholder p:first-child {
		color: var(--lab-amber);
	}

	.placeholder p:last-child {
		color: var(--lab-muted);
		font-size: clamp(18px, 2vw, 22px);
	}

	.topic-navigation {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.topic-navigation a {
		display: flex;
		gap: 14px;
		align-items: center;
		min-height: 92px;
		padding: 20px;
		color: var(--lab-text);
		text-decoration: none;
		border: 1px solid rgba(245, 241, 232, 0.1);
		background: rgba(255, 255, 255, 0.026);
		transition:
			border-color 220ms ease,
			background 220ms ease,
			transform 220ms ease;
	}

	.topic-navigation a:hover {
		border-color: rgba(146, 232, 255, 0.36);
		background: rgba(255, 255, 255, 0.045);
		transform: translateY(-2px);
	}

	.topic-navigation .next {
		justify-content: flex-end;
		text-align: right;
	}

	.nav-label {
		display: block;
		color: var(--lab-faint);
	}

	.nav-title {
		display: block;
		margin-top: 6px;
		font-size: 18px;
		font-weight: 720;
		line-height: 1.15;
	}

	@media (max-width: 680px) {
		.map-panel {
			grid-template-columns: 1fr;
		}

		.topic-shell {
			padding: 28px 20px;
		}

		.topic-navigation {
			grid-template-columns: 1fr;
		}

		.topic-navigation .next {
			justify-content: space-between;
			text-align: left;
		}
	}
</style>
